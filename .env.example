# Repath Environment Configuration
# ================================
# Copy this file to .env and fill in your values.
# At minimum you need: OPENAI_API_KEY and REPATH_API_TOKEN

# ── LLM Provider API Keys ──────────────────────────────────────────────────────
# At least one is required. The judge evaluator uses OPENAI_API_KEY.

# OpenAI (required for LLM judge — even if using Anthropic/Gemini for main traffic)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic Claude — uncomment to use Anthropic as baseline/candidate
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Google Gemini — uncomment to use Gemini as baseline/candidate
# GEMINI_API_KEY=your-gemini-api-key-here

# OpenRouter — acts as universal fallback hub (100+ models via one key)
# If set, Repath automatically uses OpenRouter as last-resort fallback
# when all configured providers are down. Free to sign up: openrouter.ai
# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Repath Core ────────────────────────────────────────────────────────────────

# Management API Token — secures /api/v1/* endpoints
# Generate: openssl rand -hex 32
REPATH_API_TOKEN=change-me-generate-with-openssl-rand-hex-32

# ── Infrastructure ─────────────────────────────────────────────────────────────

REPATH_DATABASE_URL=postgres://repath:repath_dev_password@localhost:5433/repath
REPATH_REDIS_URL=redis://localhost:6379

# ── Gateway ────────────────────────────────────────────────────────────────────

REPATH_SERVER_PORT=8080
REPATH_SERVER_HOST=0.0.0.0
RUST_LOG=info,repath_gateway=debug,repath_controller=debug

# ── Controller ─────────────────────────────────────────────────────────────────

REPATH_CONTROLLER_DECISION_INTERVAL_SECONDS=30
REPATH_CONTROLLER_MIN_SAMPLES_PER_DECISION=100

# ── Evaluator ──────────────────────────────────────────────────────────────────

REPATH_EVALUATION_SAMPLE_RATE=1.0

# ── Cloud Mode (for hosted deployment — leave empty for self-hosted) ──────────

# REPATH_CLOUD_MODE=true
# REPATH_CLOUD_DOMAIN=cloud.repath.dev
